{
  "name": "atlas-single-target-module",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ATLAS(SingleTargetModule) public single-target autonomous software delivery runtime",
  "scripts": {
    "build": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "atlas:start": "node --import tsx src/cli.ts start",
    "atlas:stop": "node --import tsx src/cli.ts stop",
    "atlas:once": "node --import tsx src/cli.ts once",
    "atlas:dashboard": "node --import tsx src/dashboard/live_dashboard.ts",
    "worker:run": "node --import tsx src/workers/run_task.ts",
    "doctor": "node --import tsx src/cli.ts doctor"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
